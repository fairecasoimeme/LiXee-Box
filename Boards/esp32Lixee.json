{
  "build": {
    "arduino":{
      "ldscript": "esp32_out.ld",
      "partitions": "default_16MB.csv"
    },
    "core": "esp32",
    "extra_flags":[
      "-DARDUINO_ESP32_DEV",
      "-DARDUINO_RUNNING_CORE=0",
      "-DARDUINO_EVENT_RUNNING_CORE=1"
    ],
    "f_cpu": "240000000L",
    "f_flash": "40000000L",
    "flash_mode": "dio",
    "mcu": "esp32",
    "variant": "esp32"
  },
  "connectivity": [
    "wifi",
    "bluetooth",
    "ethernet",
    "can"
  ],
  "debug": {
    "openocd_board": "esp-wroom-32.cfg"
  },
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "name": "Espressif ESP32 LiXee Module",
  "upload": {
    "flash_size": "16MB",
    "maximum_ram_size": 4521984,
    "maximum_size": 16777216,
    "require_upload_port": true,
    "speed": 460800
  },
  "url": "https://en.wikipedia.org/wiki/ESP32",
  "vendor": "Espressif"
}
